# ── Noderouter Core Deployment ─────────────────────────────────────────────────
# Copy this file to .env, then run: docker compose up -d
#
# TIP: Use the setup script at ../scripts/setup.sh (Linux/Mac) or
#      ../scripts/setup.ps1 (Windows) to fill this in interactively.

# ── Image ──────────────────────────────────────────────────────────────────────
# Docker Hub image to pull. Use a specific tag in production (e.g. :1.2.3).
CORE_IMAGE=06042013/noderouter-core:latest

# ── Network ────────────────────────────────────────────────────────────────────
# HTTP port exposed on the host (UI + API)
CORE_PORT=3000
# Bind to all interfaces so runners on other hosts can reach core.
# Set to 127.0.0.1 if you put a reverse proxy (nginx, Caddy) in front.
CORE_BIND_ADDR=0.0.0.0

# gRPC ports — reachable inside the Docker network only (nginx fronts externally).
# Change these only if the defaults (50051/50052) conflict with another service.
GRPC_PORT=50051
GRPC_ENROLL_PORT=50052

# ── Database ───────────────────────────────────────────────────────────────────
# Full DSN — point to any reachable PostgreSQL instance
# Format: postgresql://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgresql://noderouter:CHANGE_ME@localhost:5432/noderouter?sslmode=disable

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=production

# ── Secrets — generate each with: openssl rand -hex 32 ─────────────────────────
JWT_SECRET=                 # REQUIRED — 64-char hex
PAIRING_KEY=                # REQUIRED — 64-char hex
# This value must match RUNNER_SECRET in every runner's .env
RUNNER_SECRET=              # REQUIRED — 64-char hex

# Admin panel initial password (can be changed after first login)
ADMIN_PASSWORD=             # REQUIRED
