# ── Noderouter nginx + certbot ─────────────────────────────────────────────────
# Copy to .env and fill in values before running an init script.
#
# LOCAL DEV  (private server, no public domain):
#   bash init-self-signed.sh     # generates self-signed cert
#   docker compose --env-file .env up -d
#
# PRODUCTION (public server, DNS A record pointing to this host):
#   bash init-certs.sh           # issues Let's Encrypt cert
#   docker compose --env-file .env up -d

# Domain name served by nginx — no protocol, no trailing slash
DOMAIN_NAME=core.example.com

# Email for Let's Encrypt account registration and expiry notifications
# (only used by init-certs.sh; not needed for self-signed)
CERTBOT_EMAIL=admin@example.com

# Set to 1 to use Let's Encrypt staging CA during testing (avoids rate limits)
# Set to 0 for production certificates
CERTBOT_STAGING=0
