# ── Noderouter Runner Deployment ───────────────────────────────────────────────
# Copy this file to .env, then run: docker compose up -d
#
# TIP: Use the setup script at ../scripts/setup.sh (Linux/Mac) or
#      ../scripts/setup.ps1 (Windows) to fill this in interactively.

# ── Image ──────────────────────────────────────────────────────────────────────
# Docker Hub image to pull. Use a specific tag in production (e.g. :1.2.3).
RUNNER_IMAGE=06042013/noderouter-runner:latest

# ── Runner identity ────────────────────────────────────────────────────────────
# Unique name for this runner instance.
# Used as the container hostname — core registers it under this name.
# Change this if you run more than one runner on the same host.
RUNNER_NAME=node1

# ── Core connection (gRPC mTLS) ────────────────────────────────────────────────
# CORE_GRPC_TARGET   — mTLS Tunnel listener (bidi stream, long-lived connection)
# CORE_ENROLL_TARGET — plaintext Enroll listener (one short RPC per reconnect)
#
# Docker-internal runner (same Docker network as core — most common):
CORE_GRPC_TARGET=noderouter-core:50051
CORE_ENROLL_TARGET=noderouter-core:50052
#
# Remote runner via NGINX TCP passthrough (different host):
# CORE_GRPC_TARGET=core.example.com:8443
# CORE_ENROLL_TARGET=core.example.com:8444

# ── Database connection ────────────────────────────────────────────────────────
# Must point to the same PostgreSQL instance that noderouter-core uses.
# The runner connects directly to postgres for:
#   • Loading app code blobs at startup (avoids shared volume with core)
#   • Async job queue via LISTEN/NOTIFY
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=            # REQUIRED

# ── Auth ───────────────────────────────────────────────────────────────────────
# Must be identical to RUNNER_SECRET in core's .env.
# Copy the value from there — do not generate a new one here.
RUNNER_SECRET=           # REQUIRED — copy from core/.env

# ── Optional ───────────────────────────────────────────────────────────────────
# Leave NODE_ID blank for auto-registration (recommended).
# Set it only if you need to pin this runner to a specific pre-created node UUID.
NODE_ID=

# Concurrency tuning
ASYNC_MAX_WORKERS=4
SYNC_MAX_WORKERS=8
