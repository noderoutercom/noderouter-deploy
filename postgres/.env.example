# ── PostgreSQL Deployment ──────────────────────────────────────────────────────
# Copy this file to .env, then run: docker compose up -d
#
# Core and runner connect via the shared noderouter Docker network as:
#   postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@noderouter-postgres:<POSTGRES_PORT>/<POSTGRES_DB>

# Port exposed on the host (used only for direct DB access tools like psql/DBeaver)
POSTGRES_PORT=5432

# Database credentials — use strong values in production
POSTGRES_USER=noderouter
POSTGRES_PASSWORD=          # REQUIRED — no default; choose a strong password
POSTGRES_DB=noderouter
