# ── PostgreSQL Deployment ──────────────────────────────────────────────────────
# Copy this file to .env, then run: docker compose up -d
#
# After startup, your DATABASE_URL for core and runner will be:
#   postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@<this-host>:<POSTGRES_PORT>/<POSTGRES_DB>

# Bind address for the host-side port.
#   127.0.0.1  → localhost only (safe default; use a reverse proxy or tunnel for remote access)
#   0.0.0.0    → all interfaces (required if core/runner run on different hosts)
POSTGRES_BIND_ADDR=127.0.0.1

# Port exposed on the host
POSTGRES_PORT=5432

# Database credentials — use strong values in production
POSTGRES_USER=noderouter
POSTGRES_PASSWORD=          # REQUIRED — no default; choose a strong password
POSTGRES_DB=noderouter
